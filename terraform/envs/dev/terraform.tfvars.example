project_id           = "your-gcp-project-id"
region               = "europe-west6"
kubernetes_namespace = "sap-integration-dev"
gke_node_locations   = ["europe-west6-a"]
gke_disk_type        = "pd-standard"
gke_disk_size_gb     = 50
gke_services_cidr    = "10.50.0.0/20"
private_service_range_address = "10.30.0.0"

# Dev auto-detects the current workstation public IP at terraform plan/apply time.
# Keep this list for additional stable CIDRs such as VPN egress or office networks.
auto_detect_workstation_public_ip = true
master_authorized_networks        = []

additional_labels = {
  owner = "platform-engineering"
  cost  = "demo"
}
