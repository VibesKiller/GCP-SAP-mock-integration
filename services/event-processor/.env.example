SERVICE_NAME=event-processor
ENVIRONMENT=local
LOG_LEVEL=info
PORT=8082
KAFKA_BROKERS=localhost:9092
KAFKA_AUTH_MODE=none
KAFKA_TLS_ENABLED=false
KAFKA_TLS_INSECURE_SKIP_VERIFY=false
KAFKA_TLS_SERVER_NAME=
KAFKA_TLS_CA_CERT_FILE=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
KAFKA_GCP_PRINCIPAL_EMAIL=
KAFKA_GCP_ACCESS_TOKEN_SCOPE=https://www.googleapis.com/auth/cloud-platform
KAFKA_CLIENT_ID=event-processor
KAFKA_CONSUMER_GROUP=sap-integration.event-processor.v1
KAFKA_TOPICS=sap.sales-orders.v1,sap.customers.v1,sap.invoices.v1
KAFKA_DLQ_TOPIC=sap.integration.dlq.v1
KAFKA_COMMIT_TIMEOUT=5s
PROCESSOR_RETRY_MAX_ATTEMPTS=3
PROCESSOR_RETRY_BACKOFF=2s
POSTGRES_URL=postgres://integration:replace-with-local-dev-password@localhost:5432/integration?sslmode=disable
HTTP_READ_TIMEOUT=5s
HTTP_WRITE_TIMEOUT=10s
HTTP_IDLE_TIMEOUT=30s
